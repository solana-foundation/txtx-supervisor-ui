{
    "compilerOptions": {
        "esModuleInterop": true,
        "jsx": "react",
        "strict": true,
        "skipLibCheck": true,
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "resolveJsonModule": true
    },
    "exclude": ["node_modules"]
}
